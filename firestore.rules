<!DOCTYPE html>
<html lang="pt-BR">
<head>
  <meta charset="UTF-8" />
  <meta name="viewport" content="width=device-width, initial-scale=1.0" />
  <title>Cadastro de Equipes</title>
  <link rel="stylesheet" href="style.css?v=20260622-clean-v2" />
</head>
<body>
  <header class="topbar">
    <div class="brand"><div class="logo"><img src="assets/bioglow-logo.png?v=20260622-clean-v2" alt="BIOGLOW"></div><div><div>Cadastro de Equipes</div><small>Adicione as equipes da competição</small></div></div>
    <nav class="nav">
      <a href="index.html">Pontuação</a>
      <a href="dashboard.html" target="_blank">Dashboard</a>
    </nav>
  </header>

  <main class="container">
    <section class="card">
      <h2>Nova equipe</h2>
      <div class="grid-2">
        <label>Número
          <input id="numeroEquipe" placeholder="Ex: 01" />
        </label>
        <label>Nome da equipe
          <input id="nomeEquipe" placeholder="Ex: AtomTech" />
        </label>
        <label>Robô
          <input id="nomeRobo" placeholder="Opcional" />
        </label>
        <label>Escola/Turma
          <input id="escolaEquipe" placeholder="Opcional" />
        </label>
      </div>
      <button id="addEquipeBtn">Adicionar equipe</button>
    </section>

    <section class="card">
      <h2>Equipes cadastradas</h2>
      <div id="listaEquipes" class="team-list"></div>
    </section>
  </main>

  <div id="toast" class="toast"></div>
  <script type="module" src="js/visual-settings.js?v=20260622-clean-v2"></script>
  <script type="module" src="js/equipes.js?v=20260622-clean-v2"></script>
</body>
</html>
